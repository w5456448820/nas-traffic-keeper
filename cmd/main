#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
PORT_FILE="${TRIM_PKGVAR}/.port"

APP_DIR=""
for d in "${TRIM_PKGVAR}/app" "${TRIM_APPDEST}/server"; do
    if [ -f "${d}/traffic-keeper.sh" ]; then APP_DIR="$d"; break; fi
done
[ -z "$APP_DIR" ] && { echo "$(date) - ERROR: no traffic-keeper.sh" >> "${LOG_FILE}"; exit 1; }

DATA_DIR="${TRIM_PKGVAR}/data"
DISPLAY_DIR="${TRIM_PKGVAR}/流量统计"
ENV_FILE="${TRIM_PKGVAR}/.env"

WEB_PORT="8080"
if [ -f "${PORT_FILE}" ]; then
    WEB_PORT=$(head -n 1 "${PORT_FILE}" | tr -d '[:space:]')
fi

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

start_process() {
    if status; then
        return 0
    fi

    log_msg "Starting Traffic Keeper (port=${WEB_PORT})..."

    export TK_APP_DIR="$APP_DIR"
    export TK_DATA_DIR="$DATA_DIR"
    export TK_DISPLAY_DIR="$DISPLAY_DIR"
    export TK_ENV_FILE="$ENV_FILE"
    export TK_LOG_FILE="$LOG_FILE"
    export TK_PID_DIR="${TRIM_PKGVAR}"
    export TK_WEB_PORT="${WEB_PORT}"

    mkdir -p "$DATA_DIR/links" "$DISPLAY_DIR"
    [ -f "$ENV_FILE" ] || touch "$ENV_FILE"

    pkill -f "webserver.py" 2>/dev/null || true
    pkill -f "traffic-keeper.sh" 2>/dev/null || true
    sleep 1

    bash "${APP_DIR}/traffic-keeper.sh" >> ${LOG_FILE} 2>&1 &
    echo -n "$!" > ${PID_FILE}
    log_msg "traffic-keeper.sh started (PID: $!)"

    sleep 1

    python3 "${APP_DIR}/webserver.py" >> ${LOG_FILE} 2>&1 &
    log_msg "webserver.py started (PID: $!, port: ${WEB_PORT})"

    return 0
}

stop_process() {
    log_msg "Stopping Traffic Keeper..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            log_msg "remove pid file"
            pkill -f "webserver.py" 2>/dev/null || true
            return 0
        fi
        kill -TERM ${pid} 2>/dev/null
        local count=0
        while check_process "${pid}" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done
        if check_process "${pid}"; then
            kill -KILL "${pid}" 2>/dev/null
            sleep 1
        fi
        rm -f "${PID_FILE}"
    fi

    pkill -f "webserver.py" 2>/dev/null || true
    pkill -f "traffic-keeper.sh" 2>/dev/null || true
    log_msg "Stopped"
    return 0
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
